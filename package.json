{
  "name": "kleisterjs",
  "version": "4.0.0",
  "description": "OpenAPI client for Kleister",
  "homepage": "https://github.com/kleister/kleister-js#readme",
  "license": "Apache-2.0",
  "author": "Thomas Boerger <thomas@webhippie.de>",
  "repository": {
    "type": "git",
    "url": "https://github.com/kleister/kleister-js.git"
  },
  "bugs": {
    "url": "https://github.com/kleister/kleister-js/issues",
    "email": "kleister@webhippie.de"
  },
  "keywords": [
    "axios",
    "typescript",
    "openapi-client",
    "openapi-generator",
    "minecraft",
    "technic"
  ],
  "main": "./dist/index.js",
  "typings": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist/",
    "build": "tsc && tsc -p tsconfig.esm.json",
    "format": "prettier -w '**/*.{js,ts}'"
  },
  "dependencies": {
    "axios": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "24.12.2",
    "prettier": "3.8.2",
    "typescript": "6.0.2"
  },
  "publishConfig": {
    "provenance": true
  }
}
